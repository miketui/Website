# Curls & Contemplation — environment variable template.
#
# Copy this to .env.local for local dev (already gitignored) and fill in
# real values. NEVER commit a file containing real secrets — set production
# values directly in Vercel Dashboard → Website → Settings → Environment
# Variables → Production instead. See docs/VERCEL-ENV-VARIABLES.md for the
# full reference with descriptions, live MailerLite group IDs, and setup
# notes for every variable below.

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://curlscontemplation.beauty
NEXT_PUBLIC_LAUNCH_MODE=preorder
RELEASE_DATE=2026-07-14
SUPPORT_EMAIL=support@curlscontemplation.beauty

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=curls-deliverables

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREORDER=
STRIPE_PRICE_ID_REGULAR=
STRIPE_PRICE_ID_CARD_DECK=

# ---- MailerLite (1 API key + 11 group IDs — verify all 11 against the
# MailerLite dashboard/API before deploying; see docs/VERCEL-ENV-VARIABLES.md) ----
MAILERLITE_API_KEY=
MAILERLITE_GROUP_SUBSCRIBERS=
MAILERLITE_GROUP_FREE_CHAPTER=
MAILERLITE_GROUP_PREORDERS=
MAILERLITE_GROUP_CUSTOMERS=
MAILERLITE_GROUP_ABANDONED_CHECKOUT=
MAILERLITE_GROUP_BONUS_CLAIM_STARTED=
MAILERLITE_GROUP_BONUS_CLAIM_COMPLETED=
MAILERLITE_GROUP_REFUNDED=
MAILERLITE_GROUP_BLOG_READERS=
MAILERLITE_GROUP_VIP_EARLY_READERS=
MAILERLITE_GROUP_QUIZ=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Turnstile (bot protection on public forms) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Analytics ----
# GA4: the measurement ID is public-safe (ships to the browser). The API
# secret is server-only, used only if/when Measurement Protocol server-side
# events are added — not required for the standard gtag.js pageview tag.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
GA4_API_SECRET=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---- Sentry ----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- Admin / ops ----
ADMIN_EMAILS=
CRON_SECRET=

# ---- Launch-day fulfillment (see docs/curls-launch-day-runbook.md) ----
# Kill-switch: the launch-day cron sends NOTHING unless this is exactly "true".
# Leave false/absent until launch morning (2026-07-14, ~07:30 America/Los_Angeles).
LAUNCH_FULFILLMENT_ENABLED=false
# Single test address the dry-run harness delivers to (never real buyers).
LAUNCH_DRYRUN_TEST_EMAIL=
# Where guard failures and the July 13 pre-launch report are emailed.
LAUNCH_OWNER_EMAIL=
ALLOW_DEMO_SESSION=
# ^ Must be ABSENT (not even set to "false") in Production. See
# docs/VERCEL-ENV-VARIABLES.md for why this one is different from every
# other boolean-looking flag.

# ---- Optional / cosmetic ----
NEXT_PUBLIC_THANKYOU_VIDEO_ID=
