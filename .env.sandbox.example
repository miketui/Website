# Curls & Contemplation author-site sandbox environment template.
# Copy this file to .env.sandbox or .env.local for local sandbox verification only.
# NEVER commit .env.local, .env.sandbox, or real secrets.
# Use sandbox/test-mode credentials only. Production/live keys are blocked until launch approval.

# Site / launch controls (local or Vercel Preview URL only unless intentionally testing a sandbox domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LAUNCH_MODE=preorder
NEXT_PUBLIC_PREORDER_PRICE=17.99
NEXT_PUBLIC_REGULAR_PRICE=19.99
NEXT_PUBLIC_KINDLE_PRICE=9.99
NEXT_PUBLIC_PAPERBACK_PRICE=29.99
RELEASE_DATE=2026-06-10
# Set to true only when a non-production sandbox domain has been intentionally approved.
ALLOW_PRODUCTION_DOMAIN_FOR_SANDBOX=false

# Supabase sandbox project: Project Settings > API. Service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-sandbox-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_sandbox_anon_key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=curls-deliverables

# Stripe Dashboard test mode: Developers > API keys, Products > Prices, Developers > Webhooks.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_test_publishable_key
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=replace_with_stripe_test_webhook_secret
STRIPE_PRICE_ID_PREORDER=replace_with_preorder_test_price_id
STRIPE_PRICE_ID_REGULAR=replace_with_regular_test_price_id
STRIPE_PRICE_ID_BUNDLE=
STRIPE_PRICE_ID_WORKSHEETS=
# Future subscription placeholders only; do not activate a live subscription offer in v1.
STRIPE_PRICE_ID_MEMBERSHIP_MONTHLY=
STRIPE_PRICE_ID_MEMBERSHIP_YEARLY=

# Resend sandbox/test sender. Verify production SPF/DKIM/DMARC before real recipient sends.
RESEND_API_KEY=
RESEND_FROM_EMAIL=sandbox@example.test
SUPPORT_EMAIL=support@example.test

# MailerLite sandbox groups. Use group IDs from MailerLite sandbox/test account only.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_SUBSCRIBERS=replace_with_group_id_subscribers
MAILERLITE_GROUP_FREE_CHAPTER=replace_with_group_id_free_chapter
MAILERLITE_GROUP_PREORDERS=replace_with_group_id_preorders
MAILERLITE_GROUP_CUSTOMERS=replace_with_group_id_customers
MAILERLITE_GROUP_ABANDONED_CHECKOUT=replace_with_group_id_abandoned_checkout
MAILERLITE_GROUP_BONUS_CLAIM_STARTED=replace_with_group_id_bonus_claim_started
MAILERLITE_GROUP_BONUS_CLAIM_COMPLETED=replace_with_group_id_bonus_claim_completed
MAILERLITE_GROUP_REFUNDED=replace_with_group_id_refunded
MAILERLITE_GROUP_BLOG_READERS=replace_with_group_id_blog_readers
MAILERLITE_GROUP_VIP_EARLY_READERS=replace_with_group_id_vip_early_readers
MAILERLITE_WEBHOOK_SECRET=replace_with_mailerlite_sandbox_webhook_secret

# Cloudflare Turnstile sandbox/test widget. Public site key is safe for client use; secret remains server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_test_site_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_test_secret_key

# Internal secrets for local/sandbox-only token checks. Replace locally, never commit real values.
DOWNLOAD_TOKEN_SECRET=replace_with_download_token_secret
CRON_SECRET=replace_with_cron_secret
ADMIN_EMAILS=admin@example.test

# Analytics / observability sandbox values. Consent mode must block marketing analytics until accepted.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-REPLACE_SANDBOX
GA4_API_SECRET=replace_with_ga4_sandbox_api_secret
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=replace_with_posthog_sandbox_public_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=replace_with_posthog_sandbox_personal_api_key
